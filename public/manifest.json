{
  "manifest_version": 3,
  "name": "GPTicket",
  "description": "Assistente de suporte com IA",
  "version": "1.0",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://tuna.movidesk.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://tuna.movidesk.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"    }
  ],
  "action": {
    "default_title": "GPTicket"
  }
}